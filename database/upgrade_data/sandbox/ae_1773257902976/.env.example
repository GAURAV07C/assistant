# Required
GROQ_API_KEY=your_groq_api_key_here

# Optional fallbacks
# GROQ_API_KEY_2=your_second_key
# GROQ_API_KEY_3=your_third_key

# Optional
GROQ_MODEL=llama-3.3-70b-versatile
TAVILY_API_KEY=your_tavily_api_key_here
ASSISTANT_NAME=Jarvis
JARVIS_USER_TITLE=Sir
PORT=8001

# Optional: override database directory.
# By default TS backend auto-uses ../database (same as Python backend) if present.
# DB_DIR=/absolute/path/to/database
